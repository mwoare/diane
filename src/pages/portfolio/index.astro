---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('portfolio')).sort(
  (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0)
);
---

<Layout title="Portfolio" description="Curated interior design and remodel projects by Diane Rosellini and Associates.">
  <Header />
  <main>
    <section class="section">
      <div class="container">
        <h1 class="page-title">Portfolio</h1>
        <p class="page-intro">A selection of our recent work in new construction, remodels, cabinetry, and furniture design.</p>
        <div class="portfolio-grid">
          {projects.map((project) => (
            <a href={`/portfolio/${project.slug}/`} class="card">
              {project.data.image && (
                <img src={project.data.image} alt={project.data.title} class="card-img" />
              )}
              <div class="card-body">
                <h2 class="card-title">{project.data.title}</h2>
                {project.data.description && <p class="card-desc">{project.data.description}</p>}
                {project.data.date && (
                  <time class="card-date" datetime={project.data.date.toISOString()}>
                    {project.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
                  </time>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .section {
    padding: var(--space-xl) 0;
  }

  .page-title {
    text-align: center;
    margin-bottom: var(--space-xs);
  }

  .page-intro {
    text-align: center;
    max-width: 36rem;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: var(--space-lg);
  }

  .portfolio-grid {
    display: grid;
    gap: var(--space-lg);
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  }

  .card {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  }

  .card-img {
    aspect-ratio: 4/3;
    object-fit: cover;
    width: 100%;
  }

  .card-body {
    padding: var(--space-md);
  }

  .card-title {
    font-size: 1.125rem;
    margin-bottom: var(--space-xs);
  }

  .card-desc {
    font-size: 0.9375rem;
    margin: 0 0 var(--space-xs);
  }

  .card-date {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
</style>
